# Copy to .env and adjust if needed.

# Kafka
KAFKA_BROKER=localhost:9092
TOPIC_IN=agent_events
TOPIC_OUT=agent_metrics
TOPIC_PARTITIONS=24

# Postgres
PG_HOST=localhost
PG_PORT=5432
PG_DB=agentsdb
PG_USER=postgres
PG_PASSWORD=postgres

# Generator
GEN_RATE_PER_SEC=25         # messages per second
GEN_DRY_RUN=0               # 1 = print to stdout instead of sending to Kafka

# Flink
FLINK_KAFKA_JAR=flink/jars/flink-sql-connector-kafka-4.0.1-2.0.jar
FLINK_REST_PORT=8081
FLINK_PARALLELISM=1         # 1 keeps the event-time watermark advancing at low rates
WINDOW_MINUTES=1
MAX_OUT_OF_ORDERNESS_SEC=90

# Dashboard
DASHBOARD_PORT=8088
